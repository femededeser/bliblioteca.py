import sqlite3
from tkinter import *
from tkinter import ttk
from tkinter import messagebox
from datetime import datetime

# VENTANA
ventana = Tk()
ventana.title("Sistema de Biblioteca")

# CONEXION A BASE DE DATOS
conexion = sqlite3.connect("biblioteca.db")
cursor = conexion.cursor()

# CREAR TABLA
cursor.execute("""
CREATE TABLE IF NOT EXISTS libros(
    codigo TEXT,
    titulo TEXT,
    autor TEXT,
    estado TEXT,
    estudiante TEXT,
    id_estudiante TEXT,
    fecha_prestamo TEXT,
    fecha_devolucion TEXT
)
""")
conexion.commit()

# AGREGAR LIBRO
def agregar_libro():

    codigo = entry_codigo.get()
    titulo = entry_titulo.get()
    autor = entry_autor.get()

    if codigo != "" and titulo != "" and autor != "":

        # VERIFICAR CODIGO DUPLICADO
        cursor.execute("SELECT codigo FROM libros WHERE codigo=?", (codigo,))
        if cursor.fetchone():
            messagebox.showwarning("Aviso", "Ya existe un libro con ese código")
            return

        # GUARDAR EN BASE DE DATOS
        cursor.execute(
            "INSERT INTO libros VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
            (codigo, titulo, autor, "Disponible", "", "", "", "")
        )
        conexion.commit()

        tabla.insert(
            "",
            END,
            values=(codigo, titulo, autor, "Disponible", "", "", "", "")
        )

        entry_codigo.delete(0, END)
        entry_titulo.delete(0, END)
        entry_autor.delete(0, END)

    else:
        messagebox.showwarning("Aviso", "Completa todos los campos")

# FUNCION ELIMINAR LIBRO
def eliminar_libro():

    seleccionado = tabla.selection()

    if seleccionado:

        valores = tabla.item(seleccionado, "values")
        codigo = valores[0]

        # ELIMINAR DE SQLITE
        cursor.execute(
            "DELETE FROM libros WHERE codigo=?",
            (codigo,)
        )
        conexion.commit()

        # ELIMINAR DE TABLA
        tabla.delete(seleccionado)

        messagebox.showinfo("Correcto", "Libro eliminado")

    else:
        messagebox.showwarning("Aviso", "Seleccione un libro")

# PRESTAR LIBRO
def prestar_libro():

    seleccionado = tabla.selection()

    if seleccionado:

        valores = tabla.item(seleccionado, "values")

        # VERIFICAR QUE NO ESTE YA PRESTADO
        if valores[3] == "Prestado":
            messagebox.showwarning("Aviso", "Este libro ya está prestado")
            return

        estudiante = entry_estudiante.get()
        id_estudiante = entry_id_estudiante.get()
        fecha_prestamo = datetime.now().strftime("%d/%m/%Y")

        if estudiante == "" or id_estudiante == "":
            messagebox.showwarning("Aviso", "Ingrese nombre e ID del estudiante")
            return

        # ACTUALIZAR TABLA VISUAL
        tabla.item(
            seleccionado,
            values=(
                valores[0],
                valores[1],
                valores[2],
                "Prestado",
                estudiante,
                id_estudiante,
                fecha_prestamo,
                ""
            )
        )

        # ACTUALIZAR SQLITE
        cursor.execute(
            """
            UPDATE libros
            SET estado=?, estudiante=?, id_estudiante=?, fecha_prestamo=?
            WHERE codigo=?
            """,
            ("Prestado", estudiante, id_estudiante, fecha_prestamo, valores[0])
        )
        conexion.commit()

        entry_estudiante.delete(0, END)
        entry_id_estudiante.delete(0, END)

    else:
        messagebox.showwarning("Aviso", "Seleccione un libro")

# DEVOLVER LIBRO
def devolver_libro():

    seleccionado = tabla.selection()

    if seleccionado:

        valores = tabla.item(seleccionado, "values")

        # VERIFICAR QUE ESTE PRESTADO
        if valores[3] == "Disponible":
            messagebox.showwarning("Aviso", "Este libro ya está disponible")
            return

        fecha_devolucion = datetime.now().strftime("%d/%m/%Y")

        # ACTUALIZAR TABLA VISUAL
        tabla.item(
            seleccionado,
            values=(
                valores[0],
                valores[1],
                valores[2],
                "Disponible",
                "",
                "",
                valores[6],
                fecha_devolucion
            )
        )

        # ACTUALIZAR SQLITE
        cursor.execute(
            """
            UPDATE libros
            SET estado=?, estudiante=?, id_estudiante=?, fecha_devolucion=?
            WHERE codigo=?
            """,
            ("Disponible", "", "", fecha_devolucion, valores[0])
        )
        conexion.commit()

        messagebox.showinfo("Correcto", "Libro devuelto")

    else:
        messagebox.showwarning("Aviso", "Seleccione un libro")

# FUNCION MOSTRAR REPORTE
def mostrar_reporte():

    total = len(tabla.get_children())
    disponibles = 0
    prestados = 0

    for item in tabla.get_children():
        valores = tabla.item(item, "values")
        if valores[3] == "Disponible":
            disponibles += 1
        else:
            prestados += 1

    resumen = f"""
REPORTE DE BIBLIOTECA

 Total de libros: {total}
 Disponibles: {disponibles}
 Prestados: {prestados}
"""

    # VENTANA REPORTE
    ventana_reporte = Toplevel(ventana)
    ventana_reporte.title("Reporte de Préstamos")

    Label(ventana_reporte, text=resumen, justify=LEFT).pack(pady=10)

    # LISTAR LIBROS PRESTADOS DESDE SQLITE
    libros_prestados = cursor.execute(
        "SELECT * FROM libros WHERE estado='Prestado'"
    ).fetchall()

    if libros_prestados:
        Label(
            ventana_reporte,
            text="Libros prestados:",
            font=("Arial", 10, "bold")
        ).pack()
        for libro in libros_prestados:
            Label(
                ventana_reporte,
                text=f"{libro[0]} - {libro[1]} - {libro[4]} (ID: {libro[5]})"
            ).pack()
    else:
        Label(ventana_reporte, text="No hay libros prestados actualmente.").pack()

# CERRAR APLICACION
def cerrar_app():
    conexion.close()
    ventana.destroy()

ventana.protocol("WM_DELETE_WINDOW", cerrar_app)

